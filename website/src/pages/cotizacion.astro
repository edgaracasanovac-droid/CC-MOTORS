---
import MainLayout from "../layouts/MainLayout.astro";
import Navbar from "../components/common/Navbar.astro";
import Footer from "../components/common/Footer.astro";

import { getVehiculos } from "../services/api";

const vehiculos = await getVehiculos();
---

<MainLayout
  title="Cotización | CC Motors"
  description="Solicita una cotización personalizada"
>
  <Navbar />

  <section class="py-20 bg-gray-50">
    <div class="max-w-5xl mx-auto px-6">
      <div class="text-center mb-14">
        <span class="inline-flex bg-red-50 text-red-600 px-4 py-2 rounded-full text-sm font-bold">
          Cotización Online
        </span>

        <h1 class="text-5xl md:text-6xl font-black text-gray-950 mt-4">
          Solicita tu cotización
        </h1>

        <p class="text-gray-600 text-lg mt-4 max-w-3xl mx-auto">
          Completa el formulario y uno de nuestros asesores te contactará.
        </p>
      </div>

      <div class="bg-white rounded-[2rem] p-8 md:p-12 border border-gray-100 shadow-sm">
        <form id="cotizacionForm" class="space-y-6">
          <div class="grid md:grid-cols-2 gap-6">
            <div>
              <label class="block text-sm font-bold mb-2">Nombre</label>
              <input name="nombre" required type="text" class="w-full border border-gray-300 rounded-xl px-4 py-3" />
            </div>

            <div>
              <label class="block text-sm font-bold mb-2">Apellido</label>
              <input name="apellido" required type="text" class="w-full border border-gray-300 rounded-xl px-4 py-3" />
            </div>
          </div>

          <div class="grid md:grid-cols-2 gap-6">
            <div>
              <label class="block text-sm font-bold mb-2">Documento</label>
              <input name="documento" required type="text" placeholder="V12345678" class="w-full border border-gray-300 rounded-xl px-4 py-3" />
            </div>

            <div>
              <label class="block text-sm font-bold mb-2">Teléfono</label>
              <input name="telefono" required type="tel" class="w-full border border-gray-300 rounded-xl px-4 py-3" />
            </div>
          </div>

          <div class="grid md:grid-cols-2 gap-6">
            <div>
              <label class="block text-sm font-bold mb-2">Correo</label>
              <input name="correo" required type="email" class="w-full border border-gray-300 rounded-xl px-4 py-3" />
            </div>

            <div>
              <label class="block text-sm font-bold mb-2">Dirección</label>
              <input name="direccion" required type="text" class="w-full border border-gray-300 rounded-xl px-4 py-3" />
            </div>
          </div>

          <div>
            <label class="block text-sm font-bold mb-2">Vehículo de interés</label>

            <select name="vehiculo" required class="w-full border border-gray-300 rounded-xl px-4 py-3">
              <option value="">Seleccione un vehículo</option>

              {
                vehiculos.map((vehiculo) => (
                  <option
                    value={JSON.stringify({
                      id_vehiculo: vehiculo.id_vehiculo,
                      precio_venta: vehiculo.precio_venta,
                    })}
                  >
                    {vehiculo.nombre_marca} {vehiculo.nombre_modelo} - ${vehiculo.precio_venta}
                  </option>
                ))
              }
            </select>
          </div>

          <div>
            <label class="block text-sm font-bold mb-2">Tipo de compra</label>

            <select name="tipo_compra" required class="w-full border border-gray-300 rounded-xl px-4 py-3">
              <option value="">Seleccione una opción</option>
              <option value="contado">Contado</option>
              <option value="financiamiento">Financiamiento</option>
            </select>
          </div>

          <div>
            <label class="block text-sm font-bold mb-2">Mensaje</label>
            <textarea name="mensaje" rows="5" class="w-full border border-gray-300 rounded-xl px-4 py-3"></textarea>
          </div>

          <button
            id="submitBtn"
            type="submit"
            class="w-full bg-red-600 hover:bg-red-700 text-white py-4 rounded-xl font-black text-lg transition"
          >
            Solicitar cotización
          </button>
        </form>

        <div
          id="successMessage"
          class="hidden mt-8 bg-green-100 border border-green-300 text-green-800 p-5 rounded-xl"
        >
          ✅ Tu solicitud fue registrada correctamente en el sistema.
        </div>

        <div
          id="errorMessage"
          class="hidden mt-8 bg-red-100 border border-red-300 text-red-800 p-5 rounded-xl"
        >
          ❌ Ocurrió un error al registrar la cotización.
        </div>
      </div>
    </div>
  </section>

  <Footer />
</MainLayout>

<script>
  const API_URL = "http://localhost:3000/api";

  const form = document.getElementById("cotizacionForm");
  const btn = document.getElementById("submitBtn");
  const success = document.getElementById("successMessage");
  const errorBox = document.getElementById("errorMessage");

  form?.addEventListener("submit", async (e) => {
    e.preventDefault();

    success.classList.add("hidden");
    errorBox.classList.add("hidden");

    btn.textContent = "Enviando...";
    btn.disabled = true;

    const formData = new FormData(form);
    const vehiculoSeleccionado = JSON.parse(formData.get("vehiculo"));

    const cliente = {
      nombre: formData.get("nombre"),
      apellido: formData.get("apellido"),
      documento: formData.get("documento"),
      telefono: formData.get("telefono"),
      correo: formData.get("correo"),
      direccion: formData.get("direccion"),
    };

    try {
      const clienteResponse = await fetch(`${API_URL}/clientes`, {
        method: "POST",
        headers: {
          "Content-Type": "application/json",
        },
        body: JSON.stringify(cliente),
      });

      if (!clienteResponse.ok) {
        throw new Error("No se pudo registrar el cliente");
      }

      const clienteCreado = await clienteResponse.json();

      const fechaActual = new Date();
      const fechaVigencia = new Date();
      fechaVigencia.setDate(fechaActual.getDate() + 7);

      const cotizacion = {
        id_cliente: clienteCreado.id_cliente,
        id_vehiculo: vehiculoSeleccionado.id_vehiculo,
        precio_estimado: Number(vehiculoSeleccionado.precio_venta),
        vigencia: fechaVigencia.toISOString().split("T")[0],
        estado: "pendiente",
      };

      const cotizacionResponse = await fetch(`${API_URL}/cotizaciones`, {
        method: "POST",
        headers: {
          "Content-Type": "application/json",
        },
        body: JSON.stringify(cotizacion),
      });

      if (!cotizacionResponse.ok) {
        throw new Error("No se pudo registrar la cotización");
      }

      success.classList.remove("hidden");
      form.reset();

      window.scrollTo({
        top: document.body.scrollHeight,
        behavior: "smooth",
      });
    } catch (error) {
      console.error(error);
      errorBox.classList.remove("hidden");
    } finally {
      btn.textContent = "Solicitar cotización";
      btn.disabled = false;
    }
  });
</script>