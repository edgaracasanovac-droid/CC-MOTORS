---
import MainLayout from "../../layouts/MainLayout.astro";
import Navbar from "../../components/common/Navbar.astro";
import Footer from "../../components/common/Footer.astro";

import {
  getVehiculos,
  getVehiculoPorId,
  formatPrice,
} from "../../services/api";

export async function getStaticPaths() {
  const vehiculos = await getVehiculos();

  return vehiculos.map((vehiculo) => ({
    params: {
      id: String(vehiculo.id_vehiculo),
    },
  }));
}

const { id } = Astro.params;

const vehiculo = await getVehiculoPorId(id);

const imagenesVehiculos = {
  Toyota:
    "https://images.unsplash.com/photo-1553440569-bcc63803a83d?q=80&w=1800",
  Ford:
    "https://images.unsplash.com/photo-1492144534655-ae79c964c9d7?q=80&w=1800",
  Chevrolet:
    "https://images.unsplash.com/photo-1503376780353-7e6692767b70?q=80&w=1800",
  Hyundai:
    "https://images.unsplash.com/photo-1549399542-7e3f8b79c341?q=80&w=1800",
  BMW:
    "https://images.unsplash.com/photo-1555215695-3004980ad54e?q=80&w=1800",
};

const imagenDefault =
  "https://images.unsplash.com/photo-1502877338535-766e1452684a?q=80&w=1800";

const imagenVehiculo =
  vehiculo && (imagenesVehiculos[vehiculo.nombre_marca] || imagenDefault);
---

<MainLayout
  title={vehiculo ? `${vehiculo.nombre_marca} ${vehiculo.nombre_modelo} | CC Motors` : "Vehículo | CC Motors"}
  description="Detalle de vehículo disponible en Casanova Contreras Motors"
>
  <Navbar />

  {
    vehiculo ? (
      <main class="bg-[#07070a] text-white overflow-hidden">
        <section class="relative min-h-screen flex items-end">
          <img
            src={imagenVehiculo}
            alt={`${vehiculo.nombre_marca} ${vehiculo.nombre_modelo}`}
            class="absolute inset-0 h-full w-full object-cover"
          />

          <div class="absolute inset-0 bg-black/65"></div>
          <div class="absolute inset-0 bg-gradient-to-t from-[#07070a] via-black/45 to-black/10"></div>

          <div class="relative z-10 max-w-7xl mx-auto px-6 pb-20 pt-36 w-full">
            <div class="max-w-4xl">
              <p class="text-red-500 uppercase tracking-[0.35em] text-sm font-black">
                Vehículo disponible
              </p>

              <h1 class="text-6xl md:text-8xl font-black mt-5 leading-[0.9] uppercase">
                {vehiculo.nombre_marca}
                <span class="block text-red-600">
                  {vehiculo.nombre_modelo}
                </span>
              </h1>

              <p class="text-5xl font-black text-white mt-8">
                {formatPrice(vehiculo.precio_venta)}
              </p>

              <div class="flex flex-wrap gap-4 mt-10">
                <a
                  href="/cotizacion"
                  class="bg-red-600 hover:bg-red-700 text-white px-9 py-4 rounded-xl font-black transition shadow-2xl shadow-red-600/30"
                >
                  Solicitar cotización
                </a>

                <a
                  href="/catalogo"
                  class="border border-white/30 hover:bg-white hover:text-black text-white px-9 py-4 rounded-xl font-black transition"
                >
                  Volver al catálogo
                </a>
              </div>
            </div>
          </div>
        </section>

        <section class="relative py-24 bg-[#07070a]">
          <div class="max-w-7xl mx-auto px-6">
            <div class="grid lg:grid-cols-3 gap-8">
              <div class="lg:col-span-2 bg-[#171820] border border-white/10 rounded-3xl p-8">
                <p class="text-red-500 uppercase tracking-[0.30em] text-sm font-black">
                  Descripción
                </p>

                <h2 class="text-4xl font-black mt-4">
                  Información del vehículo
                </h2>

                <p class="text-gray-400 text-lg leading-relaxed mt-6">
                  Este vehículo forma parte del catálogo oficial de CC Motors y
                  se encuentra registrado en el sistema administrativo conectado
                  a PostgreSQL. Desde esta página puedes revisar sus datos
                  principales y solicitar una cotización personalizada.
                </p>
              </div>

              <div class="bg-[#171820] border border-red-600/40 rounded-3xl p-8">
                <p class="text-gray-500 uppercase text-xs font-black">
                  Estado
                </p>

                <p class="text-3xl font-black text-red-600 capitalize mt-2">
                  {vehiculo.estado}
                </p>

                <div class="border-t border-white/10 my-6"></div>

                <p class="text-gray-500 uppercase text-xs font-black">
                  Precio de venta
                </p>

                <p class="text-4xl font-black mt-2">
                  {formatPrice(vehiculo.precio_venta)}
                </p>
              </div>
            </div>

            <div class="mt-10 grid sm:grid-cols-2 lg:grid-cols-3 gap-6">
              <div class="bg-[#171820] border border-white/10 rounded-3xl p-7 transition hover:border-red-500">
                <p class="text-gray-500 text-xs uppercase font-black">
                  Año
                </p>
                <p class="text-3xl font-black mt-3">
                  {vehiculo.ano}
                </p>
              </div>

              <div class="bg-[#171820] border border-white/10 rounded-3xl p-7 transition hover:border-red-500">
                <p class="text-gray-500 text-xs uppercase font-black">
                  Color
                </p>
                <p class="text-3xl font-black mt-3 capitalize">
                  {vehiculo.color}
                </p>
              </div>

              <div class="bg-[#171820] border border-white/10 rounded-3xl p-7 transition hover:border-red-500">
                <p class="text-gray-500 text-xs uppercase font-black">
                  Kilometraje
                </p>
                <p class="text-3xl font-black mt-3">
                  {vehiculo.kilometraje}
                </p>
              </div>

              <div class="bg-[#171820] border border-white/10 rounded-3xl p-7 transition hover:border-red-500">
                <p class="text-gray-500 text-xs uppercase font-black">
                  Placa
                </p>
                <p class="text-3xl font-black mt-3">
                  {vehiculo.placa}
                </p>
              </div>

              <div class="bg-[#171820] border border-white/10 rounded-3xl p-7 transition hover:border-red-500">
                <p class="text-gray-500 text-xs uppercase font-black">
                  Proveedor
                </p>
                <p class="text-3xl font-black mt-3">
                  {vehiculo.nombre_proveedor || "No registrado"}
                </p>
              </div>

              <div class="bg-[#171820] border border-white/10 rounded-3xl p-7 transition hover:border-red-500">
                <p class="text-gray-500 text-xs uppercase font-black">
                  Precio compra
                </p>
                <p class="text-3xl font-black mt-3">
                  {formatPrice(vehiculo.precio_compra)}
                </p>
              </div>
            </div>

            <div class="mt-12 relative rounded-[2rem] overflow-hidden bg-black min-h-[420px]">
              <img
                src={imagenVehiculo}
                alt={`${vehiculo.nombre_marca} ${vehiculo.nombre_modelo}`}
                class="absolute inset-0 h-full w-full object-cover opacity-70"
              />

              <div class="absolute inset-0 bg-gradient-to-r from-black via-black/70 to-transparent"></div>

              <div class="relative z-10 p-10 md:p-14 max-w-3xl">
                <p class="text-red-500 uppercase tracking-[0.35em] text-sm font-black">
                  Cotización online
                </p>

                <h2 class="text-5xl md:text-6xl font-black mt-5 leading-tight">
                  ¿Te interesa este vehículo?
                </h2>

                <p class="text-gray-300 text-lg mt-6">
                  Solicita una cotización y el administrador recibirá tu solicitud
                  automáticamente por correo y en el sistema.
                </p>

                <a
                  href="/cotizacion"
                  class="inline-flex mt-10 bg-red-600 hover:bg-red-700 text-white px-9 py-4 rounded-xl font-black transition shadow-2xl shadow-red-600/30"
                >
                  Cotizar ahora
                </a>
              </div>
            </div>
          </div>
        </section>
      </main>
    ) : (
      <section class="min-h-screen bg-[#07070a] text-white flex items-center justify-center text-center px-6">
        <div>
          <h1 class="text-5xl font-black">
            Vehículo no encontrado
          </h1>

          <a
            href="/catalogo"
            class="inline-flex mt-8 bg-red-600 text-white px-6 py-3 rounded-xl font-black"
          >
            Volver al catálogo
          </a>
        </div>
      </section>
    )
  }

  <Footer />
</MainLayout>