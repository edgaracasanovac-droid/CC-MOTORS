---
import MainLayout from "../layouts/MainLayout.astro";
import Navbar from "../components/common/Navbar.astro";
import { API_URL } from "../services/api";
---

<MainLayout
  title="Restablecer contraseña | CC Motors"
  description="Crea una nueva contraseña para tu cuenta CC Motors"
>
  <Navbar />

  <section class="relative min-h-screen bg-[#07070a] text-white flex items-center justify-center px-6 py-28 overflow-hidden">
    <div class="absolute inset-0 bg-[radial-gradient(circle_at_top,rgba(220,38,38,0.18),transparent_35%)]"></div>

    <div class="relative w-full max-w-md bg-[#171820] border border-white/10 rounded-[2rem] p-8 shadow-[0_0_70px_rgba(220,38,38,0.12)]">
      <div class="text-center mb-8">
        <h1 class="text-4xl font-black">
          CC <span class="text-red-600">Motors</span>
        </h1>

        <div class="mx-auto mt-6 h-16 w-16 rounded-full border border-red-600 flex items-center justify-center text-red-600 text-3xl">
          🔑
        </div>

        <h2 class="text-3xl font-black mt-5">
          Restablecer contraseña
        </h2>

        <p class="text-gray-400 mt-3 leading-relaxed">
          Ingresa tu nueva contraseña para recuperar el acceso a tu cuenta.
        </p>
      </div>

      <form id="resetForm" class="space-y-5">
        <div>
          <label class="block text-sm font-bold mb-2 text-gray-300">
            Nueva contraseña
          </label>

          <input
            name="nueva_contrasena"
            required
            minlength="6"
            type="password"
            placeholder="Mínimo 6 caracteres"
            class="w-full bg-white/5 border border-white/10 text-white placeholder:text-gray-500 rounded-xl px-4 py-3 focus:outline-none focus:border-red-500"
          />
        </div>

        <div>
          <label class="block text-sm font-bold mb-2 text-gray-300">
            Confirmar contraseña
          </label>

          <input
            name="confirmar_contrasena"
            required
            minlength="6"
            type="password"
            placeholder="Repite tu contraseña"
            class="w-full bg-white/5 border border-white/10 text-white placeholder:text-gray-500 rounded-xl px-4 py-3 focus:outline-none focus:border-red-500"
          />
        </div>

        <button
          id="submitBtn"
          type="submit"
          class="w-full bg-red-600 hover:bg-red-700 text-white py-4 rounded-xl font-black text-lg transition disabled:opacity-60"
        >
          Restablecer contraseña
        </button>
      </form>

      <div
        id="successMessage"
        class="hidden mt-6 bg-green-500/10 border border-green-500/30 text-green-300 p-4 rounded-xl text-sm"
      ></div>

      <div
        id="errorMessage"
        class="hidden mt-6 bg-red-500/10 border border-red-500/30 text-red-300 p-4 rounded-xl text-sm"
      ></div>

      <div class="text-center mt-6">
        <a href="/login" class="text-sm text-red-500 hover:text-red-400 transition font-bold">
          Volver al login
        </a>
      </div>
    </div>
  </section>
</MainLayout>

<script define:vars={{ API_URL }}>
  const params = new URLSearchParams(window.location.search);
  const token = params.get("token");

  const form = document.getElementById("resetForm");
  const btn = document.getElementById("submitBtn");
  const successMessage = document.getElementById("successMessage");
  const errorMessage = document.getElementById("errorMessage");

  if (!token) {
    form.classList.add("hidden");
    errorMessage.textContent =
      "❌ El enlace de recuperación no es válido o no contiene token.";
    errorMessage.classList.remove("hidden");
  }

  form?.addEventListener("submit", async (e) => {
    e.preventDefault();

    successMessage.classList.add("hidden");
    errorMessage.classList.add("hidden");

    const formData = new FormData(form);
    const nuevaContrasena = formData.get("nueva_contrasena");
    const confirmarContrasena = formData.get("confirmar_contrasena");

    if (nuevaContrasena.length < 6) {
      errorMessage.textContent =
        "❌ La contraseña debe tener mínimo 6 caracteres.";
      errorMessage.classList.remove("hidden");
      return;
    }

    if (nuevaContrasena !== confirmarContrasena) {
      errorMessage.textContent =
        "❌ Las contraseñas no coinciden.";
      errorMessage.classList.remove("hidden");
      return;
    }

    btn.textContent = "Guardando...";
    btn.disabled = true;

    try {
      const response = await fetch(`${API_URL}/auth/restablecer-contrasena`, {
        method: "POST",
        headers: {
          "Content-Type": "application/json",
        },
        body: JSON.stringify({
          token,
          nueva_contrasena: nuevaContrasena,
        }),
      });

      const data = await response.json();

      if (!response.ok) {
        throw new Error(data?.mensaje || "Error al restablecer contraseña");
      }

      form.reset();

      successMessage.textContent =
        data?.mensaje || "✅ Contraseña actualizada correctamente.";
      successMessage.classList.remove("hidden");

      setTimeout(() => {
        window.location.href = "/login";
      }, 2500);
    } catch (error) {
      console.error(error);

      errorMessage.textContent =
        "❌ No se pudo restablecer la contraseña. El enlace puede estar vencido o ser inválido.";
      errorMessage.classList.remove("hidden");
    } finally {
      btn.textContent = "Restablecer contraseña";
      btn.disabled = false;
    }
  });
</script>