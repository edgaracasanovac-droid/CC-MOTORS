---
import MainLayout from "../layouts/MainLayout.astro";
import Navbar from "../components/common/Navbar.astro";
import Footer from "../components/common/Footer.astro";
---

<MainLayout
  title="Nosotros | CC Motors"
  description="Conoce la historia, misión y visión de Casanova Contreras Motors"
>
  <Navbar />

  <main class="bg-[#07070a] text-white overflow-hidden">
    <section class="relative min-h-screen flex items-end">
      <img
        src="https://images.unsplash.com/photo-1562141961-3086c9cf9d9a?q=80&w=2200"
        alt="Concesionaria CC Motors"
        class="absolute inset-0 h-full w-full object-cover"
      />

      <div class="absolute inset-0 bg-black/70"></div>
      <div class="absolute inset-0 bg-gradient-to-t from-[#07070a] via-black/50 to-black/10"></div>

      <div class="relative z-10 max-w-7xl mx-auto px-6 pb-24 pt-36 w-full">
        <p class="text-red-500 uppercase tracking-[0.35em] text-sm font-black">
          Casanova Contreras Motors
        </p>

        <h1 class="text-6xl md:text-8xl font-black mt-5 leading-[0.9] uppercase max-w-5xl">
          Más que vender autos,
          <span class="block text-red-600">
            creamos confianza
          </span>
        </h1>

        <p class="text-gray-300 text-lg md:text-xl mt-8 max-w-3xl leading-relaxed">
          CC Motors nace como una concesionaria moderna enfocada en brindar
          vehículos certificados, atención personalizada y una experiencia digital
          clara, segura y profesional.
        </p>
      </div>
    </section>

    <section class="relative py-28">
      <div class="absolute inset-0 bg-[radial-gradient(circle_at_top,rgba(220,38,38,0.12),transparent_35%)]"></div>

      <div class="relative max-w-7xl mx-auto px-6">
        <div class="grid lg:grid-cols-2 gap-14 items-center">
          <div>
            <p class="text-red-500 uppercase tracking-[0.35em] text-sm font-black">
              Nuestra historia
            </p>

            <h2 class="text-5xl md:text-6xl font-black mt-5 leading-tight">
              Una concesionaria con visión
              <span class="text-red-600"> tecnológica</span>
            </h2>

            <p class="text-gray-400 text-lg leading-relaxed mt-7">
              CC Motors fue diseñada como una plataforma integral para conectar
              clientes con vehículos de manera eficiente. La website pública,
              el panel administrativo y el backend trabajan juntos para gestionar
              vehículos, clientes, cotizaciones, ventas y solicitudes desde un
              sistema centralizado.
            </p>

            <p class="text-gray-400 text-lg leading-relaxed mt-5">
              Nuestro enfoque combina el trato humano de una concesionaria
              tradicional con herramientas digitales modernas que permiten
              consultar vehículos, solicitar cotizaciones y recibir atención
              personalizada desde cualquier lugar.
            </p>
          </div>

          <div class="relative rounded-[2rem] overflow-hidden border border-white/10 shadow-[0_0_60px_rgba(220,38,38,0.12)]">
            <img
              src="https://images.unsplash.com/photo-1517524008697-84bbe3c3fd98?q=80&w=1600"
              alt="Vehículos CC Motors"
              class="h-[520px] w-full object-cover"
            />
            <div class="absolute inset-0 bg-gradient-to-t from-black/70 to-transparent"></div>
          </div>
        </div>
      </div>
    </section>

    <section class="py-24 bg-[#0b0c11]">
      <div class="max-w-7xl mx-auto px-6">
        <div class="grid md:grid-cols-3 gap-8">
          <article class="bg-[#171820] border border-white/10 rounded-3xl p-8 hover:border-red-500 transition">
            <p class="text-red-500 text-4xl mb-5">🎯</p>
            <h3 class="text-3xl font-black">Misión</h3>
            <p class="text-gray-400 mt-5 leading-relaxed">
              Ofrecer vehículos confiables y certificados mediante una atención
              profesional, transparente y apoyada en tecnología.
            </p>
          </article>

          <article class="bg-[#171820] border border-white/10 rounded-3xl p-8 hover:border-red-500 transition">
            <p class="text-red-500 text-4xl mb-5">🚀</p>
            <h3 class="text-3xl font-black">Visión</h3>
            <p class="text-gray-400 mt-5 leading-relaxed">
              Convertirnos en una concesionaria referente por su innovación,
              confianza y facilidad para gestionar procesos de compra online.
            </p>
          </article>

          <article class="bg-[#171820] border border-white/10 rounded-3xl p-8 hover:border-red-500 transition">
            <p class="text-red-500 text-4xl mb-5">🤝</p>
            <h3 class="text-3xl font-black">Valores</h3>
            <p class="text-gray-400 mt-5 leading-relaxed">
              Transparencia, responsabilidad, compromiso, seguridad y atención
              personalizada en cada proceso con nuestros clientes.
            </p>
          </article>
        </div>
      </div>
    </section>

    <section class="relative py-28">
      <div class="max-w-7xl mx-auto px-6">
        <div class="text-center max-w-4xl mx-auto mb-16">
          <p class="text-red-500 uppercase tracking-[0.35em] text-sm font-black">
            Por qué elegirnos
          </p>

          <h2 class="text-5xl md:text-6xl font-black mt-5">
            Tecnología, confianza y
            <span class="text-red-600"> experiencia</span>
          </h2>
        </div>

        <div class="grid md:grid-cols-2 lg:grid-cols-4 gap-6">
          <div class="bg-[#171820] border border-white/10 rounded-3xl p-7 text-center hover:border-red-500 transition">
            <p class="text-5xl font-black text-red-600">01</p>
            <h3 class="text-xl font-black mt-5">Catálogo real</h3>
            <p class="text-gray-400 mt-3">
              Vehículos obtenidos directamente desde el backend.
            </p>
          </div>

          <div class="bg-[#171820] border border-white/10 rounded-3xl p-7 text-center hover:border-red-500 transition">
            <p class="text-5xl font-black text-red-600">02</p>
            <h3 class="text-xl font-black mt-5">Cotización online</h3>
            <p class="text-gray-400 mt-3">
              Solicitudes registradas en PostgreSQL y notificadas por correo.
            </p>
          </div>

          <div class="bg-[#171820] border border-white/10 rounded-3xl p-7 text-center hover:border-red-500 transition">
            <p class="text-5xl font-black text-red-600">03</p>
            <h3 class="text-xl font-black mt-5">Área cliente</h3>
            <p class="text-gray-400 mt-3">
              Registro, login, recuperación y restablecimiento de contraseña.
            </p>
          </div>

          <div class="bg-[#171820] border border-white/10 rounded-3xl p-7 text-center hover:border-red-500 transition">
            <p class="text-5xl font-black text-red-600">04</p>
            <h3 class="text-xl font-black mt-5">Gestión integral</h3>
            <p class="text-gray-400 mt-3">
              Website, backend y panel administrativo conectados.
            </p>
          </div>
        </div>
      </div>
    </section>

    <section class="relative min-h-[60vh] flex items-center overflow-hidden">
      <img
        src="https://images.unsplash.com/photo-1503736334956-4c8f8e92946d?q=80&w=2200"
        alt="Vehículo CC Motors"
        class="absolute inset-0 h-full w-full object-cover"
      />

      <div class="absolute inset-0 bg-black/75"></div>
      <div class="absolute inset-0 bg-gradient-to-r from-black via-black/70 to-transparent"></div>

      <div class="relative z-10 max-w-7xl mx-auto px-6 w-full py-24">
        <div class="max-w-3xl">
          <p class="text-red-500 uppercase tracking-[0.35em] text-sm font-black">
            CC Motors
          </p>

          <h2 class="text-5xl md:text-7xl font-black mt-5 leading-tight">
            Tu próxima compra merece
            <span class="block text-red-600">
              una experiencia mejor
            </span>
          </h2>

          <p class="text-gray-300 text-lg mt-6 leading-relaxed">
            Explora nuestro catálogo, configura tu compra o solicita una
            cotización personalizada.
          </p>

          <div class="flex flex-wrap gap-4 mt-10">
            <a
              href="/catalogo"
              class="bg-red-600 hover:bg-red-700 text-white px-8 py-4 rounded-xl font-black transition"
            >
              Ver catálogo
            </a>

            <a
              href="/cotizacion"
              class="border border-white/30 hover:bg-white hover:text-black text-white px-8 py-4 rounded-xl font-black transition"
            >
              Solicitar cotización
            </a>
          </div>
        </div>
      </div>
    </section>
  </main>

  <Footer />
</MainLayout>