---
import MainLayout from "../layouts/MainLayout.astro";
import Navbar from "../components/common/Navbar.astro";
import Footer from "../components/common/Footer.astro";

import { getVehiculos, API_URL } from "../services/api";

const vehiculos = await getVehiculos();
---

<MainLayout
  title="Test Drive | CC Motors"
  description="Agenda una visita o prueba de manejo con CC Motors"
>
  <Navbar />

  <section class="relative min-h-screen bg-[#07070a] text-white overflow-hidden">
    <div class="absolute inset-0 bg-[radial-gradient(circle_at_top_right,rgba(220,38,38,0.16),transparent_35%)]"></div>

    <div class="grid lg:grid-cols-2 min-h-screen">
      <div class="relative hidden lg:block">
        <img
          src="https://images.unsplash.com/photo-1492144534655-ae79c964c9d7?q=80&w=1800"
          alt="Test Drive CC Motors"
          class="absolute inset-0 h-full w-full object-cover"
        />

        <div class="absolute inset-0 bg-black/65"></div>
        <div class="absolute inset-0 bg-gradient-to-r from-black/80 via-black/45 to-transparent"></div>

        <div class="relative z-10 h-full flex items-end p-12">
          <div>
            <p class="text-red-500 uppercase tracking-[0.35em] text-sm font-black">
              Experiencia CC Motors
            </p>

            <h1 class="text-6xl xl:text-7xl font-black mt-5 leading-[0.9] uppercase">
              Agenda tu
              <span class="block text-red-600">
                Test Drive
              </span>
            </h1>

            <p class="text-gray-300 text-lg mt-6 max-w-xl leading-relaxed">
              Selecciona el vehículo de tu interés, elige una fecha y nuestro equipo
              confirmará tu visita desde el sistema.
            </p>

            <div class="grid grid-cols-3 gap-4 mt-10 max-w-xl">
              <div class="bg-white/10 border border-white/10 rounded-2xl p-4 backdrop-blur-md">
                <p class="text-2xl font-black">1</p>
                <p class="text-gray-400 text-sm">Elige modelo</p>
              </div>

              <div class="bg-white/10 border border-white/10 rounded-2xl p-4 backdrop-blur-md">
                <p class="text-2xl font-black">2</p>
                <p class="text-gray-400 text-sm">Agenda fecha</p>
              </div>

              <div class="bg-white/10 border border-white/10 rounded-2xl p-4 backdrop-blur-md">
                <p class="text-2xl font-black">3</p>
                <p class="text-gray-400 text-sm">Confirmamos</p>
              </div>
            </div>
          </div>
        </div>
      </div>

      <div class="relative flex items-center justify-center px-4 sm:px-6 py-24 md:py-28 lg:py-20">
        <div class="w-full max-w-2xl">
          <div class="mb-8 lg:hidden">
            <p class="text-red-500 uppercase tracking-[0.28em] text-xs font-black">
              CC Motors
            </p>

            <h1 class="text-4xl sm:text-5xl font-black mt-4 leading-tight">
              Agenda tu
              <span class="text-red-600"> Test Drive</span>
            </h1>

            <p class="text-gray-400 mt-4 leading-relaxed">
              Completa la solicitud y nuestro equipo confirmará tu visita.
            </p>
          </div>

          <div class="bg-white/5 border border-white/10 rounded-[2rem] p-5 sm:p-8 md:p-10 backdrop-blur-xl shadow-[0_0_60px_rgba(220,38,38,0.10)]">
            <div class="mb-8 hidden lg:block">
              <p class="text-red-500 uppercase tracking-[0.35em] text-xs font-black">
                Solicitud de visita
              </p>

              <h2 class="text-3xl md:text-4xl font-black mt-3">
                Datos del test drive
              </h2>

              <p class="text-gray-400 mt-3">
                Para agendar un test drive debes tener sesión iniciada.
              </p>
            </div>

            <div
              id="sessionInfo"
              class="hidden mb-6 bg-red-600/10 border border-red-600/30 rounded-2xl p-4 text-sm text-red-100"
            >
              Solicitud asociada a tu cuenta de CC Motors.
            </div>

            <form id="testDriveForm" class="space-y-5">
              <div>
                <label class="block text-sm font-bold mb-2 text-gray-300">
                  Vehículo de interés
                </label>

                <select
                  name="id_vehiculo"
                  required
                  class="w-full bg-white/5 border border-white/10 text-white rounded-xl px-4 py-3 focus:outline-none focus:border-red-500"
                >
                  <option value="" class="bg-[#171820]">
                    Seleccione un vehículo
                  </option>

                  {
                    vehiculos.map((vehiculo) => (
                      <option value={vehiculo.id_vehiculo} class="bg-[#171820]">
                        {vehiculo.nombre_marca} {vehiculo.nombre_modelo} - {vehiculo.ano}
                      </option>
                    ))
                  }
                </select>
              </div>

              <div class="grid grid-cols-1 md:grid-cols-2 gap-5">
                <div>
                  <label class="block text-sm font-bold mb-2 text-gray-300">
                    Fecha preferida
                  </label>

                  <input
                    name="fecha"
                    required
                    type="date"
                    class="w-full bg-white/5 border border-white/10 text-white rounded-xl px-4 py-3 focus:outline-none focus:border-red-500"
                  />
                </div>

                <div>
                  <label class="block text-sm font-bold mb-2 text-gray-300">
                    Hora preferida
                  </label>

                  <input
                    name="hora"
                    required
                    type="time"
                    class="w-full bg-white/5 border border-white/10 text-white rounded-xl px-4 py-3 focus:outline-none focus:border-red-500"
                  />
                </div>
              </div>

              <div>
                <label class="block text-sm font-bold mb-2 text-gray-300">
                  Mensaje
                </label>

                <textarea
                  name="mensaje"
                  rows="4"
                  placeholder="Indica cualquier detalle adicional..."
                  class="w-full bg-white/5 border border-white/10 text-white placeholder:text-gray-500 rounded-xl px-4 py-3 focus:outline-none focus:border-red-500 resize-none"
                ></textarea>
              </div>

              <button
                id="submitBtn"
                type="submit"
                class="w-full bg-red-600 hover:bg-red-700 text-white py-4 rounded-xl font-black text-base sm:text-lg transition disabled:opacity-60 disabled:cursor-not-allowed shadow-2xl shadow-red-600/20"
              >
                Agendar test drive
              </button>
            </form>

            <div
              id="successMessage"
              class="hidden mt-8 bg-green-500/10 border border-green-500/30 text-green-300 p-5 rounded-xl leading-relaxed"
            >
              ✅ Solicitud registrada correctamente. Puedes verla luego en Mi Cuenta.
            </div>

            <div
              id="errorMessage"
              class="hidden mt-8 bg-red-500/10 border border-red-500/30 text-red-300 p-5 rounded-xl leading-relaxed"
            >
              ❌ Ocurrió un error al enviar la solicitud.
            </div>
          </div>
        </div>
      </div>
    </div>
  </section>

  <Footer />
</MainLayout>

<script define:vars={{ API_URL }}>
  const token = localStorage.getItem("cc_motors_token");

  if (!token) {
    window.location.href = "/login";
  }

  const form = document.getElementById("testDriveForm");
  const btn = document.getElementById("submitBtn");
  const success = document.getElementById("successMessage");
  const errorBox = document.getElementById("errorMessage");
  const sessionInfo = document.getElementById("sessionInfo");

  async function cargarPerfilSesion() {
    try {
      const response = await fetch(`${API_URL}/auth/profile`, {
        headers: {
          Authorization: `Bearer ${token}`,
        },
      });

      const data = await response.json();

      if (!response.ok) return;

      const perfil = data.perfil;
      const nombre = perfil?.nombre || "cliente";

      sessionInfo.textContent = `Solicitud asociada a tu cuenta: ${nombre}.`;
      sessionInfo.classList.remove("hidden");

      localStorage.setItem("cc_motors_usuario", JSON.stringify({
        id: perfil?.id,
        nombre: perfil?.nombre || "",
        apellido: perfil?.apellido || "",
        correo: perfil?.email || perfil?.correo || "",
        email: perfil?.email || perfil?.correo || "",
        rol: perfil?.rol || "cliente",
      }));
    } catch (error) {
      console.error("No se pudo cargar el perfil:", error);
    }
  }

  cargarPerfilSesion();

  form?.addEventListener("submit", async (e) => {
    e.preventDefault();

    success.classList.add("hidden");
    errorBox.classList.add("hidden");

    btn.textContent = "Enviando solicitud...";
    btn.disabled = true;

    const formData = new FormData(form);

    const datosTestDrive = {
      id_vehiculo: Number(formData.get("id_vehiculo")),
      fecha: formData.get("fecha"),
      hora: formData.get("hora"),
      mensaje: formData.get("mensaje") || "Quiero agendar un test drive",
    };

    try {
      const response = await fetch(`${API_URL}/test-drive`, {
        method: "POST",
        headers: {
          "Content-Type": "application/json",
          Authorization: `Bearer ${token}`,
        },
        body: JSON.stringify(datosTestDrive),
      });

      const data = await response.json();

      if (!response.ok) {
        throw new Error(data?.mensaje || "Error al registrar test drive");
      }

      success.textContent =
        data?.mensaje || "✅ Solicitud registrada correctamente. Puedes verla luego en Mi Cuenta.";
      success.classList.remove("hidden");

      form.reset();

      window.scrollTo({
        top: document.body.scrollHeight,
        behavior: "smooth",
      });
    } catch (error) {
      console.error(error);

      errorBox.textContent =
        "❌ No se pudo registrar el test drive. Verifica tu sesión e intenta nuevamente.";
      errorBox.classList.remove("hidden");
    } finally {
      btn.textContent = "Agendar test drive";
      btn.disabled = false;
    }
  });
</script>