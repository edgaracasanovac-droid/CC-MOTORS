---
import MainLayout from "../layouts/MainLayout.astro";
import Navbar from "../components/common/Navbar.astro";
import Footer from "../components/common/Footer.astro";

import { getVehiculos, formatPrice } from "../services/api";

const vehiculos = await getVehiculos();

const imagenesVehiculos = {
  Toyota:
    "https://images.unsplash.com/photo-1553440569-bcc63803a83d?q=80&w=1200",
  Ford:
    "https://images.unsplash.com/photo-1492144534655-ae79c964c9d7?q=80&w=1200",
  Chevrolet:
    "https://images.unsplash.com/photo-1503376780353-7e6692767b70?q=80&w=1200",
  Hyundai:
    "https://images.unsplash.com/photo-1549399542-7e3f8b79c341?q=80&w=1200",
  BMW:
    "https://images.unsplash.com/photo-1555215695-3004980ad54e?q=80&w=1200",
};

const imagenDefault =
  "https://images.unsplash.com/photo-1502877338535-766e1452684a?q=80&w=1200";
---

<MainLayout
  title="Catálogo | CC Motors"
  description="Vehículos disponibles en Casanova Contreras Motors"
>
  <Navbar />

  <section class="py-20 bg-gray-50">
    <div class="max-w-7xl mx-auto px-6">
      <div class="text-center mb-16">
        <span class="inline-flex bg-red-50 text-red-600 px-4 py-2 rounded-full text-sm font-bold">
          Catálogo Oficial
        </span>

        <h1 class="text-5xl md:text-6xl font-black text-gray-950 mt-4">
          Vehículos disponibles
        </h1>

        <p class="text-gray-600 text-lg mt-4 max-w-3xl mx-auto">
          Todos los vehículos publicados desde el sistema administrativo.
        </p>
      </div>

      {
        vehiculos.length === 0 ? (
          <div class="text-center py-20">
            <h2 class="text-3xl font-black text-gray-900">
              No hay vehículos disponibles
            </h2>

            <p class="text-gray-500 mt-4">
              Agrega vehículos desde el panel administrativo.
            </p>
          </div>
        ) : (
          <div class="grid md:grid-cols-2 lg:grid-cols-3 gap-8">
            {vehiculos.map((vehiculo) => (
              <article class="bg-white rounded-[2rem] overflow-hidden border border-gray-100 shadow-sm hover:shadow-xl transition">
                <div class="relative h-64 bg-gradient-to-br from-gray-900 via-gray-800 to-black overflow-hidden">
                  <img
                    src={imagenesVehiculos[vehiculo.nombre_marca] || imagenDefault}
                    alt={`${vehiculo.nombre_marca} ${vehiculo.nombre_modelo}`}
                    class="h-full w-full object-cover"
                    onerror="this.style.display='none'; this.nextElementSibling.style.display='flex';"
                  />

                  <div class="hidden absolute inset-0 items-center justify-center text-white text-center p-6">
                    <div>
                      <div class="text-6xl mb-3">🚘</div>

                      <p class="font-black text-xl">
                        {vehiculo.nombre_marca}
                      </p>

                      <p class="text-gray-300">
                        {vehiculo.nombre_modelo}
                      </p>
                    </div>
                  </div>
                </div>

                <div class="p-6">
                  <div class="flex justify-between items-start gap-4">
                    <div>
                      <h3 class="text-2xl font-black text-gray-950">
                        {vehiculo.nombre_marca}
                      </h3>

                      <p class="text-gray-500">
                        {vehiculo.nombre_modelo}
                      </p>
                    </div>

                    <span class="text-red-600 font-black text-xl">
                      {formatPrice(vehiculo.precio_venta)}
                    </span>
                  </div>

                  <div class="grid grid-cols-2 gap-3 mt-6">
                    <div class="bg-gray-50 rounded-xl p-3">
                      <p class="text-xs text-gray-500">
                        Año
                      </p>

                      <p class="font-bold text-gray-900">
                        {vehiculo.ano}
                      </p>
                    </div>

                    <div class="bg-gray-50 rounded-xl p-3">
                      <p class="text-xs text-gray-500">
                        Color
                      </p>

                      <p class="font-bold text-gray-900">
                        {vehiculo.color}
                      </p>
                    </div>

                    <div class="bg-gray-50 rounded-xl p-3">
                      <p class="text-xs text-gray-500">
                        Estado
                      </p>

                      <p class="font-bold text-gray-900 capitalize">
                        {vehiculo.estado}
                      </p>
                    </div>

                    <div class="bg-gray-50 rounded-xl p-3">
                      <p class="text-xs text-gray-500">
                        Kilometraje
                      </p>

                      <p class="font-bold text-gray-900">
                        {vehiculo.kilometraje}
                      </p>
                    </div>
                  </div>

                  <div class="flex gap-3 mt-6">
                    <a
                      href={`/vehiculo/${vehiculo.id_vehiculo}`}
                      class="flex-1 text-center bg-gray-950 text-white py-3 rounded-xl font-bold hover:bg-black transition"
                    >
                      Ver detalles
                    </a>

                    <a
                      href="/cotizacion"
                      class="flex-1 text-center bg-red-600 text-white py-3 rounded-xl font-bold hover:bg-red-700 transition"
                    >
                      Cotizar
                    </a>
                  </div>
                </div>
              </article>
            ))}
          </div>
        )
      }
    </div>
  </section>

  <Footer />
</MainLayout>

<script>
  fetch("http://localhost:3000/api/vehiculos")
    .then((response) => response.json())
    .then((data) => {
      console.log("Vehículos traídos desde el backend:", data);
    })
    .catch((error) => {
      console.error("Error consultando backend:", error);
    });
</script>