---
---

<section class="relative min-h-screen overflow-hidden bg-black">
  <div
    class="absolute inset-0 bg-cover bg-center scale-105 animate-[heroZoom_8s_ease-out_forwards]"
    style="background-image: url('https://images.unsplash.com/photo-1533473359331-0135ef1b58bf?q=80&w=2200');"
  ></div>

  <div class="absolute inset-0 bg-black/65"></div>
  <div class="absolute inset-0 bg-gradient-to-r from-black via-black/60 to-black/20"></div>

  <div class="relative z-10 min-h-screen flex items-center">
    <div class="max-w-7xl mx-auto px-4 sm:px-6 w-full pt-24 sm:pt-28 md:pt-32">
      <div class="max-w-5xl">
        <p class="hero-kicker text-white/80 text-xs sm:text-sm md:text-base font-black uppercase tracking-[0.25em] mb-5">
          Casanova Contreras Motors
        </p>

        <h1 class="hero-title text-white text-4xl sm:text-5xl md:text-6xl lg:text-[8.5rem] font-black uppercase leading-[0.9] tracking-tight">
          Tu vehículo
          <span class="block text-red-600">
            ideal espera
          </span>
        </h1>

        <p class="hero-text text-white/80 text-base sm:text-lg md:text-xl max-w-2xl mt-7 leading-relaxed">
          Compra, cotiza y descubre vehículos certificados con una experiencia
          moderna, rápida y profesional.
        </p>

        <div class="hero-actions flex flex-col sm:flex-row gap-4 mt-9 max-w-md sm:max-w-none">
          <a
            href="/catalogo"
            class="bg-red-600 hover:bg-red-700 text-white px-7 py-4 rounded-xl transition font-black shadow-2xl shadow-red-600/30 text-center"
          >
            Explorar modelos
          </a>

          <a
            href="/cotizacion"
            class="border border-white/30 hover:bg-white hover:text-black text-white px-7 py-4 rounded-xl transition font-black backdrop-blur-sm text-center"
          >
            Agendar cotización
          </a>
        </div>
      </div>
    </div>
  </div>

  <div class="hidden sm:block absolute bottom-10 left-1/2 -translate-x-1/2 z-20 text-white/70 text-center">
    <p class="text-xs uppercase tracking-[0.35em] mb-2">Scroll</p>
    <div class="mx-auto h-8 w-px bg-white/40 animate-pulse"></div>
  </div>
</section>