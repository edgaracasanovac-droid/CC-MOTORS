---
const stats = [
  {
    value: "500+",
    label: "Vehículos gestionados",
  },
  {
    value: "1.200+",
    label: "Clientes atendidos",
  },
  {
    value: "10+",
    label: "Años de experiencia",
  },
  {
    value: "24h",
    label: "Respuesta de cotización",
  },
];
---

<section class="relative py-24 bg-[#07070a] text-white overflow-hidden">
  <div class="absolute inset-0 bg-[radial-gradient(circle_at_bottom,rgba(220,38,38,0.10),transparent_38%)]"></div>

  <div class="relative max-w-7xl mx-auto px-6">
    <div class="grid md:grid-cols-4 gap-6">
      {stats.map((stat) => (
        <article class="group bg-[#171820] border border-white/10 rounded-3xl p-8 text-center transition-all duration-500 hover:-translate-y-2 hover:border-red-500 hover:shadow-[0_0_40px_rgba(220,38,38,0.18)]">
          <h3 class="text-5xl md:text-6xl font-black text-white group-hover:text-red-600 transition">
            {stat.value}
          </h3>

          <div class="h-1 w-12 bg-red-600 mx-auto my-5 rounded-full"></div>

          <p class="text-gray-400 font-semibold">
            {stat.label}
          </p>
        </article>
      ))}
    </div>
  </div>
</section>