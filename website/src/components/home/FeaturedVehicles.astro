---
import { getVehiculos, formatPrice, getPlaceholderImage } from "../../services/api";

const allVehicles = await getVehiculos();
const vehicles = allVehicles.slice(0, 3);
---

<section id="modelos" class="relative py-20 sm:py-24 lg:py-28 bg-[#07070a] text-white overflow-hidden">
  <div class="absolute inset-0 bg-[radial-gradient(circle_at_top,rgba(220,38,38,0.14),transparent_35%)]"></div>

  <div class="relative max-w-7xl mx-auto px-4 sm:px-6">
    <div class="text-center max-w-3xl mx-auto mb-10 sm:mb-16">
      <p class="text-red-500 uppercase tracking-[0.35em] text-sm font-black">
        Configura y reserva
      </p>

      <h2 class="text-5xl md:text-6xl font-black mt-5">
        Elige tu <span class="text-red-600">modelo</span>
      </h2>

      <p class="text-gray-300 text-lg mt-5">
        Selecciona el vehículo ideal, revisa sus características y solicita una cotización directamente con CC Motors.
      </p>
    </div>

    <div class="grid gap-6 md:grid-cols-2 lg:grid-cols-3 lg:gap-8">
      {vehicles.map((vehicle) => (
        <article class="group bg-[#171820] border border-red-600/35 rounded-3xl overflow-hidden transition-all duration-500 hover:-translate-y-3 hover:border-red-500 hover:shadow-[0_0_50px_rgba(220,38,38,0.25)]">
          <div class="relative h-72 overflow-hidden">
            <img
              src={vehicle.imagen || getPlaceholderImage(vehicle.nombre_marca, vehicle.nombre_modelo)}
              alt={`${vehicle.nombre_marca} ${vehicle.nombre_modelo}`}
              class="h-full w-full object-cover transition duration-700 group-hover:scale-110"
            />

            <div class="absolute inset-0 bg-gradient-to-t from-[#171820] via-transparent to-transparent"></div>

            <span class="absolute top-5 right-5 bg-red-600 text-white px-4 py-2 rounded-full text-xs font-black uppercase">
              {vehicle.estado}
            </span>
          </div>

          <div class="p-7">
            <h3 class="text-2xl font-black">
              {vehicle.nombre_marca}
            </h3>

            <p class="text-gray-400 mt-2 text-sm">
              {vehicle.nombre_modelo} · {vehicle.color} · {vehicle.ano}
            </p>

            <p class="text-gray-300 mt-5 leading-relaxed">
              Vehículo certificado por CC Motors, ideal quienes buscan seguridad,
              rendimiento y una experiencia de compra profesional.
            </p>

            <div class="flex flex-wrap gap-2 mt-6">
              <span class="bg-white/5 border border-white/10 px-3 py-2 rounded-lg text-xs text-gray-300">
                {vehicle.color}
              </span>

              <span class="bg-white/5 border border-white/10 px-3 py-2 rounded-lg text-xs text-gray-300">
                {vehicle.kilometraje} km
              </span>

              <span class="bg-white/5 border border-white/10 px-3 py-2 rounded-lg text-xs text-gray-300">
                {vehicle.ano}
              </span>
            </div>

            <div class="border-t border-white/10 mt-7 pt-6 flex flex-col gap-4 sm:flex-row sm:items-end sm:justify-between">
              <div>
                <p class="text-gray-500 text-xs uppercase font-bold">
                  Precio estimado
                </p>

                <p class="text-3xl font-black text-red-600">
                  {formatPrice(vehicle.precio_venta)}
                </p>
              </div>

              <a
                href={`/vehiculo/${vehicle.id_vehiculo}`}
                class="w-full text-center sm:w-auto bg-red-600 hover:bg-red-700 text-white px-6 py-3 rounded-xl font-black transition shadow-lg shadow-red-600/20"
              >
                Ver detalles
              </a>
            </div>
          </div>
        </article>
      ))}
    </div>

    <div class="text-center mt-14">
      <a
        href="/catalogo"
        class="inline-flex border border-white/20 hover:bg-white hover:text-black text-white px-8 py-4 rounded-xl font-black transition"
      >
        Ver catálogo completo
      </a>
    </div>
  </div>
</section>