---
import "../styles/global.css";
import ToastProvider from "../components/ui/ToastProvider.jsx";
import { ClientRouter } from "astro:transitions";

const currentPath = Astro.url.pathname;

const menuSections = [
  {
    title: "Panel principal",
    items: [
      {
        label: "Dashboard",
        href: "/dashboard",
        icon: "📊",
      },
    ],
  },
  {
    title: "Gestión comercial",
    items: [
      {
        label: "Cotizaciones",
        href: "/dashboard/cotizaciones",
        icon: "🧾",
      },
      {
        label: "Test Drive",
        href: "/dashboard/test-drive",
        icon: "🚗",
      },
      {
        label: "Clientes",
        href: "/dashboard/clientes",
        icon: "👥",
      },
      {
        label: "Vehículos",
        href: "/dashboard/vehiculos",
        icon: "🚘",
      },
      {
        label: "Ventas",
        href: "/dashboard/ventas",
        icon: "💰",
      },
    ],
  },
  {
    title: "Finanzas",
    items: [
      {
        label: "Pagos",
        href: "/dashboard/pagos",
        icon: "💳",
      },
      {
        label: "Cuotas",
        href: "/dashboard/cuotas",
        icon: "📆",
      },
      {
        label: "Planes de financiamiento",
        href: "/dashboard/planes-financiamiento",
        icon: "🏦",
      },
    ],
  },
  {
    title: "Catálogo",
    items: [
      {
        label: "Marcas",
        href: "/dashboard/marcas",
        icon: "🏷️",
      },
      {
        label: "Modelos",
        href: "/dashboard/modelos",
        icon: "🚙",
      },
      {
        label: "Proveedores",
        href: "/dashboard/proveedores",
        icon: "🏭",
      },
    ],
  },
  {
    title: "Administración",
    items: [
      {
        label: "Usuarios",
        href: "/dashboard/usuarios",
        icon: "👤",
      },
      {
        label: "Mi perfil",
        href: "/dashboard/perfil",
        icon: "⚙️",
      },
      {
        label: "Acerca del sistema",
        href: "/dashboard/acerca",
        icon: "ℹ️",
      },
    ],
  },
];

const isActive = (href) => {
  if (href === "/dashboard") {
    return currentPath === "/dashboard";
  }

  return currentPath.startsWith(href);
};

const getLinkClass = (href) => {
  const base =
    "mb-1 flex items-center gap-3 rounded-xl px-4 py-3 text-sm font-semibold transition";

  if (isActive(href)) {
    return `${base} bg-red-600 text-white shadow-lg shadow-red-900/30`;
  }

  return `${base} text-slate-200 hover:bg-red-950/50 hover:text-red-400`;
};
---

<html lang="es">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <link rel="icon" type="image/png" href="/favicon.png" />
    <title>CC Motors | Sistema Administrativo</title>
    <ClientRouter />
  </head>

  <body class="bg-slate-100">
    <div class="min-h-screen">
      <div
        class="fixed left-0 right-0 top-0 z-40 flex items-center justify-between gap-3 bg-black px-3 py-3 text-white shadow sm:px-4 lg:hidden"
      >
        <div class="flex min-w-0 items-center gap-3">
          <img
            src="/logo-cc-motors.png"
            alt="CC Motors"
            class="h-10 w-10 shrink-0 object-contain sm:h-12 sm:w-12"
          />

          <div class="min-w-0">
            <h1 class="truncate text-lg font-black text-white sm:text-xl">CC Motors</h1>
            <p class="truncate text-[11px] text-slate-400 sm:text-xs">Sistema Administrativo</p>
          </div>
        </div>

        <button
          id="openSidebarBtn"
          class="shrink-0 rounded-xl bg-red-600 px-3 py-2 text-sm font-bold text-white transition hover:bg-red-700 sm:px-4"
        >
          ☰
        </button>
      </div>

      <div
        id="sidebarOverlay"
        class="fixed inset-0 z-40 hidden bg-black/60 lg:hidden"
      >
      </div>

      <aside
        id="sidebar"
        class="fixed left-0 top-0 z-50 flex h-screen w-72 max-w-[85vw] -translate-x-full flex-col bg-black text-white shadow-2xl transition-transform duration-300 lg:translate-x-0"
      >
        <div class="border-b border-red-950/70 p-6">
          <div class="flex items-center justify-between gap-4">
            <div class="flex items-center gap-3">
              <div
                class="flex h-14 w-14 items-center justify-center rounded-2xl bg-white/5 ring-1 ring-white/10"
              >
                <img
                  src="/logo-cc-motors.png"
                  alt="CC Motors"
                  class="h-12 w-12 object-contain"
                />
              </div>

              <div>
                <h1 class="text-xl font-black leading-tight text-white">
                  CC Motors
                </h1>
                <p class="text-xs text-slate-400">
                  Casanova Contreras Motors
                </p>
                <p class="mt-1 text-xs font-semibold text-red-500">
                  Panel Administrativo
                </p>
              </div>
            </div>

            <button
              id="closeSidebarBtn"
              class="rounded-lg bg-red-600 px-3 py-2 text-white transition hover:bg-red-700 lg:hidden"
            >
              ✕
            </button>
          </div>
        </div>

        <nav class="flex-1 overflow-y-auto px-4 py-5 scrollbar-none">
          {
            menuSections.map((section) => (
              <div class="mb-6">
                <p class="mb-2 px-3 text-xs font-black uppercase tracking-widest text-red-500">
                  {section.title}
                </p>

                <div class="space-y-1">
                  {section.items.map((item) => (
                    <a href={item.href} class={getLinkClass(item.href)}>
                      <span class="text-lg">{item.icon}</span>
                      <span>{item.label}</span>
                    </a>
                  ))}
                </div>
              </div>
            ))
          }
        </nav>

        <div class="border-t border-slate-800 p-4">
          <button
            id="logoutBtn"
            class="w-full rounded-xl bg-red-600 px-4 py-3 font-bold text-white transition hover:bg-red-700"
          >
            🚪 Cerrar sesión
          </button>
        </div>
      </aside>

      <main class="px-3 pb-8 pt-24 sm:px-6 lg:ml-72 lg:p-8">
        <div class="mx-auto w-full max-w-7xl">
          <slot />
        </div>
      </main>
    </div>

    <script>
      const logoutBtn = document.getElementById("logoutBtn");
      const openSidebarBtn = document.getElementById("openSidebarBtn");
      const closeSidebarBtn = document.getElementById("closeSidebarBtn");
      const sidebar = document.getElementById("sidebar");
      const sidebarOverlay = document.getElementById("sidebarOverlay");

      const openSidebar = () => {
        sidebar?.classList.remove("-translate-x-full");
        sidebarOverlay?.classList.remove("hidden");
      };

      const closeSidebar = () => {
        sidebar?.classList.add("-translate-x-full");
        sidebarOverlay?.classList.add("hidden");
      };

      openSidebarBtn?.addEventListener("click", openSidebar);
      closeSidebarBtn?.addEventListener("click", closeSidebar);
      sidebarOverlay?.addEventListener("click", closeSidebar);

      document.querySelectorAll("#sidebar a").forEach((link) => {
        link.addEventListener("click", () => {
          if (window.innerWidth < 1024) closeSidebar();
        });
      });

      logoutBtn?.addEventListener("click", () => {
        localStorage.removeItem("token");
        localStorage.removeItem("usuario");
        window.location.href = "/login";
      });
    </script>

    <ToastProvider client:load />
  </body>
</html>