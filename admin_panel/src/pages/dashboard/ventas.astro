---
import DashboardLayout from "../../layouts/DashboardLayout.astro";
import ProtectedRoute from "../../components/auth/ProtectedRoute.jsx";
import VentasList from "../../components/ventas/VentasList.jsx";
---

<DashboardLayout>
  <ProtectedRoute client:load />

  <div class="space-y-6">
    <div>
      <p class="mb-2 text-sm font-bold uppercase tracking-widest text-red-600">
        CC Motors
      </p>

      <h1 class="text-4xl font-black text-black">
        Gestión de ventas
      </h1>

      <p class="mt-2 text-slate-600">
        Registra y consulta las ventas de vehículos, incluyendo operaciones al contado y financiadas.
      </p>
    </div>

    <VentasList client:load />
  </div>
</DashboardLayout>