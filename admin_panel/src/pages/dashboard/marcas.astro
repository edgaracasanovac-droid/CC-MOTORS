---
import DashboardLayout from "../../layouts/DashboardLayout.astro";
import ProtectedRoute from "../../components/auth/ProtectedRoute.jsx";
import MarcasList from "../../components/marcas/MarcasList.jsx";
---

<DashboardLayout>
  <ProtectedRoute client:load />

  <div class="space-y-6">
    <div>
      <p class="mb-2 text-sm font-bold uppercase tracking-widest text-red-600">
        CC Motors
      </p>

      <h1 class="text-4xl font-black text-black">
        Gestión de marcas
      </h1>

      <p class="mt-2 text-slate-600">
        Administra las marcas disponibles para modelos y vehículos del catálogo.
      </p>
    </div>

    <MarcasList client:load />
  </div>
</DashboardLayout>