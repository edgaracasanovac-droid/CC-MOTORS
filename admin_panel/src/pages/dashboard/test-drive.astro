---
import DashboardLayout from "../../layouts/DashboardLayout.astro";
import ProtectedRoute from "../../components/auth/ProtectedRoute.jsx";
import TestDriveList from "../../components/test-drive/TestDriveList.jsx";
---

<DashboardLayout>
  <ProtectedRoute client:load />

  <div class="space-y-6">
    <div>
      <p class="mb-2 text-sm font-bold uppercase tracking-widest text-red-600">
        CC Motors
      </p>

      <h1 class="text-4xl font-black text-black">
        Solicitudes de test drive
      </h1>

      <p class="mt-2 text-slate-600">
        Visualiza el estado del módulo de pruebas de manejo generadas desde la website.
      </p>
    </div>

    <TestDriveList client:load />
  </div>
</DashboardLayout>