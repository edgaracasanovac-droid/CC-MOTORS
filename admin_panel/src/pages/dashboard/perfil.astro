---
import DashboardLayout from "../../layouts/DashboardLayout.astro";
import ProtectedRoute from "../../components/auth/ProtectedRoute.jsx";
import PerfilUsuario from "../../components/perfil/PerfilUsuario.jsx";
---

<DashboardLayout>
  <ProtectedRoute client:load />

  <div class="space-y-6">
    <div>
      <p class="mb-2 text-sm font-bold uppercase tracking-widest text-red-600">
        CC Motors
      </p>

      <h1 class="text-4xl font-black text-black">
        Mi perfil
      </h1>

      <p class="mt-2 text-slate-600">
        Consulta y actualiza la información del usuario autenticado en el panel.
      </p>
    </div>

    <PerfilUsuario client:load />
  </div>
</DashboardLayout>