---
import DashboardLayout from "../../layouts/DashboardLayout.astro";
---

<DashboardLayout>
  <div class="space-y-8">
    <div class="rounded-3xl bg-black p-8 text-white shadow-xl">
      <p class="mb-2 text-sm font-bold uppercase tracking-widest text-red-500">
        Información del sistema
      </p>

      <h1 class="text-4xl font-bold">
        Casanova Contreras Motors
      </h1>

      <p class="mt-3 text-slate-300">
        Sistema administrativo para la gestión integral de vehículos,
        clientes, ventas, pagos y financiamiento.
      </p>
    </div>

    <div class="grid gap-6 lg:grid-cols-2">
      <div class="rounded-3xl bg-white p-8 shadow">
        <h2 class="mb-4 text-2xl font-bold">
          🚗 Empresa
        </h2>

        <ul class="space-y-3 text-slate-700">
          <li><strong>Nombre:</strong> Casanova Contreras Motors</li>
          <li><strong>Siglas:</strong> CC Motors</li>
          <li><strong>Sector:</strong> Comercialización de vehículos</li>
          <li><strong>Sistema:</strong> Administrativo Web</li>
        </ul>
      </div>

      <div class="rounded-3xl bg-white p-8 shadow">
        <h2 class="mb-4 text-2xl font-bold">
          💻 Desarrollo
        </h2>

        <ul class="space-y-3 text-slate-700">
          <li><strong>Frontend:</strong> Astro + React</li>
          <li><strong>Backend:</strong> Node.js + Express</li>
          <li><strong>Base de Datos:</strong> PostgreSQL</li>
          <li><strong>Arquitectura:</strong> API REST</li>
        </ul>
      </div>
    </div>

    <div class="rounded-3xl bg-white p-8 shadow">
      <h2 class="mb-6 text-2xl font-bold">
        🎓 Información académica
      </h2>

      <div class="grid gap-6 md:grid-cols-2">
        <div>
          <p><strong>Autor:</strong></p>
          <p class="text-slate-600">
            Edgar Alexander Casanova Contreras
          </p>
        </div>

        <div>
          <p><strong>Institución:</strong></p>
          <p class="text-slate-600">
            UNEFA Núcleo Táchira
          </p>
        </div>

        <div>
          <p><strong>Asignatura:</strong></p>
          <p class="text-slate-600">
            Lenguaje de Programación III
          </p>
        </div>

        <div>
          <p><strong>Año:</strong></p>
          <p class="text-slate-600">
            2026
          </p>
        </div>
      </div>
    </div>
  </div>
</DashboardLayout>