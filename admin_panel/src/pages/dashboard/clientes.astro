---
import DashboardLayout from "../../layouts/DashboardLayout.astro";
import ProtectedRoute from "../../components/auth/ProtectedRoute.jsx";
import ClientesList from "../../components/clientes/ClientesList.jsx";
---

<DashboardLayout>
  <ProtectedRoute client:load />

  <div class="space-y-6">
    <div>
      <p class="mb-2 text-sm font-bold uppercase tracking-widest text-red-600">
        CC Motors
      </p>

      <h1 class="text-4xl font-black text-black">
        Gestión de clientes
      </h1>

      <p class="mt-2 text-slate-600">
        Administra los clientes registrados para cotizaciones, ventas y operaciones comerciales de la concesionaria.
      </p>
    </div>

    <ClientesList client:load />
  </div>
</DashboardLayout>